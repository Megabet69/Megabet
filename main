                <span>Available:</span> <span class="text-green-400 font-mono" id="withdrawAvailable"></span>
            </div>
            <div class="mb-5 sm:mb-6 relative">
                <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-400">₹</span>
                <input type="number" id="withdrawAmount" placeholder="Amount" class="w-full bg-dark border border-gray-600 rounded-xl py-3 pl-8 pr-16 text-white font-mono focus:outline-none focus:border-gray-400">
                <button onclick="setMaxWithdraw()" class="absolute inset-y-0 right-2 flex items-center px-3 text-xs font-bold text-brand hover:text-brandHover uppercase">Max</button>
            </div>
            <button onclick="confirmWithdraw()" class="w-full bg-gray-600 hover:bg-gray-500 text-white font-bold py-3.5 sm:py-4 rounded-xl transition shadow-lg text-sm sm:text-base">Withdraw</button>
        </div>
    </div>

    <!-- Toast Container -->
    <div id="toast-container"></div>

    <script>
        // --- STATE MANAGEMENT ---
        const savedUsers = JSON.parse(localStorage.getItem('megabet_users')) || {
            "9999999999": {
                mobile: "9999999999",
                password: "password123",
                balance: 1000.00,
                stats: { wagered: 0, won: 0, gamesPlayed: 0 },
                refCode: "megabet",
                totalDeposited: 5000,
                lastCheckIn: "",
                claimableCashback: 15.50
            }
        };
        const savedCurrentUser = localStorage.getItem('megabet_currentUser') || null;

        let state = {
            currentUser: savedCurrentUser,
            users: savedUsers,
            balance: savedCurrentUser && savedUsers[savedCurrentUser] ? savedUsers[savedCurrentUser].balance : 0,
            stats: savedCurrentUser && savedUsers[savedCurrentUser] ? savedUsers[savedCurrentUser].stats : {
                wagered: 0,
                won: 0,
                gamesPlayed: 0
            },
            gameIsRunning: false,
            freeSpins: 0,
            diceTarget: 'low',
            coinTarget: 'heads'
        };

        // Format Currency
        const formatMoney = (amount) => {
            return '₹' + parseFloat(amount).toFixed(2).replace(/\d(?=(\d{3})+\.)/g, '$&,');
        };

        // VIP Logic
        const getVIPLevel = (deposited) => {
            if(deposited >= 5000) return { name: "Diamond", bonus: 150, color: "text-[#84FFFF]" };
            if(deposited >= 2000) return { name: "Platinum", bonus: 50, color: "text-[#ECEFF1]" };
            if(deposited >= 500) return { name: "Gold", bonus: 20, color: "text-[#FFF59D]" };
            if(deposited >= 200) return { name: "Silver", bonus: 10, color: "text-[#F5F5F5]" };
            if(deposited >= 50) return { name: "Bronze", bonus: 5, color: "text-[#D7CCC8]" };
            return { name: "Beginner", bonus: 0, color: "text-gray-400" };
        };

        // Update UI & Save State
        const updateUI = () => {
            if (state.currentUser) {
                const user = state.users[state.currentUser];
                user.balance = state.balance;
                user.stats = state.stats;
                
                document.getElementById('balanceDisplay').innerText = formatMoney(state.balance);
                document.getElementById('statWagered').innerText = formatMoney(state.stats.wagered);
                document.getElementById('statWon').innerText = formatMoney(state.stats.won);
                document.getElementById('statGames').innerText = state.stats.gamesPlayed;
                document.getElementById('displayRefCode').innerText = user.refCode;
                
                const vip = getVIPLevel(user.totalDeposited);
                document.getElementById('dashVipLevel').innerText = vip.name.toUpperCase();
                document.getElementById('dashVipLevel').className = `text-2xl sm:text-3xl font-bold font-mono relative z-10 ${vip.color}`;
                document.getElementById('dashDailyDesc').innerText = vip.bonus > 0 ? `₹${vip.bonus} available today` : `Reach Bronze to unlock`;
                document.getElementById('dashCashback').innerText = formatMoney(user.claimableCashback);

                let nextTierText = "Max Level Reached";
                if(user.totalDeposited < 50) nextTierText = `Deposit ₹${50 - user.totalDeposited} for Bronze`;
                else if(user.totalDeposited < 200) nextTierText = `Deposit ₹${200 - user.totalDeposited} for Silver`;
                else if(user.totalDeposited < 500) nextTierText = `Deposit ₹${500 - user.totalDeposited} for Gold`;
                else if(user.totalDeposited < 2000) nextTierText = `Deposit ₹${2000 - user.totalDeposited} for Platinum`;
                else if(user.totalDeposited < 5000) nextTierText = `Deposit ₹${5000 - user.totalDeposited} for Diamond`;
                document.getElementById('dashVipProgress').innerText = nextTierText;

                document.querySelectorAll('.gameBalanceDisplay').forEach(el => el.innerText = formatMoney(state.balance));
                
                // Save to local storage
                localStorage.setItem('megabet_users', JSON.stringify(state.users));
            }

            const fsInd = document.getElementById('freeSpinsIndicator');
            const fsBtn = document.getElementById('btnSpinSlot');
            if(state.freeSpins > 0) {
                fsInd.classList.remove('hidden');
                document.getElementById('fsCount').innerText = state.freeSpins;
                if(fsBtn) {
                    fsBtn.innerText = `FREE SPIN (${state.freeSpins})`;
                    fsBtn.classList.replace('from-purple-500', 'from-yellow-500');
                    fsBtn.classList.replace('to-purple-700', 'to-yellow-700');
                    fsBtn.classList.replace('border-purple-900', 'border-yellow-900');
                }
            } else {
                if(fsInd) fsInd.classList.add('hidden');
                if(fsBtn) {
                    fsBtn.innerText = "SPIN";
                    fsBtn.classList.replace('from-yellow-500', 'from-purple-500');
                    fsBtn.classList.replace('to-yellow-700', 'to-purple-700');
                    fsBtn.classList.replace('border-yellow-900', 'border-purple-900');
                }
            }
        };

        // --- AUTHENTICATION LOGIC ---
        const generateRefCode = () => {
            return Math.random().toString(36).substring(2, 8).toLowerCase();
        };

        const validateMobile = (mobile) => {
            if (!/^[6-9]\d{9}$/.test(mobile)) {
                return "Enter a valid 10-digit mobile number starting with 6, 7, 8, or 9.";
            }
            if (/(.)\1{3}/.test(mobile)) {
                return "Mobile number cannot contain 4 consecutive identical digits.";
            }
            return null;
        };

        const switchAuthTab = (tab) => {
            if(tab === 'login') {
                document.getElementById('formLogin').classList.remove('hidden');
                document.getElementById('formRegister').classList.add('hidden');
                document.getElementById('tabLogin').classList.replace('border-transparent', 'border-brand');
                document.getElementById('tabLogin').classList.replace('text-gray-500', 'text-white');
                document.getElementById('tabRegister').classList.replace('border-brand', 'border-transparent');
                document.getElementById('tabRegister').classList.replace('text-white', 'text-gray-500');
            } else {
                document.getElementById('formRegister').classList.remove('hidden');
                document.getElementById('formLogin').classList.add('hidden');
                document.getElementById('tabRegister').classList.replace('border-transparent', 'border-brand');
                document.getElementById('tabRegister').classList.replace('text-gray-500', 'text-white');
                document.getElementById('tabLogin').classList.replace('border-brand', 'border-transparent');
                document.getElementById('tabLogin').classList.replace('text-white', 'text-gray-500');
            }
        };

        const handleRegister = () => {
            const mobile = document.getElementById('regMobile').value.trim();
            const password = document.getElementById('regPassword').value;
            const refCode = document.getElementById('regRefCode').value.trim().toLowerCase();

            const mobileError = validateMobile(mobile);
            if(mobileError) return showToast(mobileError, "error");
            if(!password || password.length < 4) return showToast("Password must be at least 4 characters", "error");
            if(state.users[mobile]) return showToast("Mobile number already registered", "error");

            let initialBalance = 1000.00;

            if(refCode) {
                let refValid = false;
                for(let key in state.users) {
                    if(state.users[key].refCode === refCode) {
                        refValid = true;
                        state.users[key].balance += 50; 
                        break;
                    }
                }
                if(refValid) {
                    initialBalance += 50;
                    showToast("Referral applied! ₹50 Bonus added.", "success");
                } else {
                    return showToast("Invalid Referral Code", "error");
                }
            }

            const newUser = {
                mobile,
                password,
                balance: initialBalance,
                stats: { wagered: 0, won: 0, gamesPlayed: 0 },
                refCode: generateRefCode(),
                totalDeposited: 0,
                lastCheckIn: "",
                claimableCashback: 0
            };

            state.users[mobile] = newUser;
            loginUser(mobile, password);
        };

        const handleLogin = () => {
            const mobile = document.getElementById('loginMobile').value.trim();
            const password = document.getElementById('loginPassword').value;

            if(!mobile || !password) return showToast("Please fill all fields", "error");

            const user = state.users[mobile];
            if(!user || user.password !== password) {
                return showToast("Invalid mobile number or password", "error");
            }

            loginUser(mobile, password);
        };

        const loginUser = (mobile, password) => {
            const user = state.users[mobile];
            state.currentUser = mobile;
            state.balance = user.balance;
            state.stats = user.stats;
            
            document.getElementById('loginMobile').value = "";
            document.getElementById('loginPassword').value = "";
            document.getElementById('regMobile').value = "";
            document.getElementById('regPassword').value = "";
            document.getElementById('regRefCode').value = "";

            localStorage.setItem('megabet_currentUser', mobile);
            updateUI();
            navigate('dashboard');
            showToast("Logged in successfully!", "success");
        };

        const logout = () => {
            if(state.gameIsRunning) return showToast("Cannot logout during a game", "error");
            
            if(state.currentUser) {
                state.users[state.currentUser].balance = state.balance;
                state.users[state.currentUser].stats = state.stats;
                localStorage.setItem('megabet_users', JSON.stringify(state.users));
            }

            state.currentUser = null;
            localStorage.removeItem('megabet_currentUser');
            navigate('auth');
            showToast("Logged out successfully", "info");
        };

        // --- NAVIGATION ---
        const navigate = (viewId) => {
            if(state.gameIsRunning) {
                showToast("Please wait for the current game to finish.", "error");
                return;
            }
            
            if(viewId !== 'auth' && !state.currentUser) {
                viewId = 'auth';
            }

            document.querySelectorAll('.view-section').forEach(el => el.classList.add('hidden'));
            document.getElementById(viewId).classList.remove('hidden');

            const isGameView = viewId.startsWith('game-');
            const mainNav = document.getElementById('mainNav');
            const mobileNav = document.getElementById('mobileNav');
            const mainFooter = document.getElementById('mainFooter');
            const mainContent = document.getElementById('mainContent');

            if (viewId === 'auth') {
                mainNav.classList.add('hidden');
                mobileNav.classList.add('hidden');
                mainFooter.classList.add('hidden');
                mainContent.classList.add('justify-center', 'my-auto');
                mainContent.classList.remove('py-6', 'pb-24', 'md:pb-8');
            } else if (isGameView) {
                mainNav.classList.add('hidden');
                mobileNav.classList.add('hidden');
                mainFooter.classList.add('hidden');
                mainContent.classList.add('justify-center');
                mainContent.classList.remove('py-6', 'pb-24', 'md:pb-8', 'my-auto');
                mainContent.classList.add('py-4', 'pb-4');
            } else {
                mainNav.classList.remove('hidden');
                mobileNav.classList.remove('hidden');
                mainFooter.classList.remove('hidden');
                mainContent.classList.remove('justify-center', 'my-auto', 'py-4', 'pb-4');
                mainContent.classList.add('py-6', 'pb-24', 'md:pb-8');
            }

            window.scrollTo({ top: 0, behavior: 'smooth' });
        };

        // --- MODALS & REWARDS ---
        const claimDaily = () => {
            if(!state.currentUser) return;
            const user = state.users[state.currentUser];
            const vip = getVIPLevel(user.totalDeposited);
            
            if(vip.bonus === 0) return showToast("Reach Bronze VIP (₹50 deposit) to claim daily!", "error");
            
            const today = new Date().toDateString();
            if(user.lastCheckIn === today) return showToast("You have already claimed your daily bonus today!", "error");

            user.balance += vip.bonus;
            user.lastCheckIn = today;
            state.balance = user.balance;
            updateUI();
            showToast(`Claimed ₹${vip.bonus} Daily Bonus!`, "success");
        };

        const claimCashback = () => {
            if(!state.currentUser) return;
            const user = state.users[state.currentUser];
            
            if(user.claimableCashback <= 0) return showToast("No accumulated cashback available to claim.", "error");
            
            const amt = user.claimableCashback;
            user.balance += amt;
            user.claimableCashback = 0;
            state.balance = user.balance;
            updateUI();
            showToast(`Claimed ₹${amt.toFixed(2)} Cashback successfully!`, "success");
        };

        const openModal = (modalId) => {
            if(state.gameIsRunning) return showToast("Cannot transact while game is running.", "error");
            if(modalId === 'withdrawModal') document.getElementById('withdrawAvailable').innerText = formatMoney(state.balance);
            const modal = document.getElementById(modalId);
            const inner = document.getElementById(modalId + 'Inner');
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                inner.classList.remove('scale-95');
            }, 10);
        };

        const closeModal = (modalId) => {
            const modal = document.getElementById(modalId);
            const inner = document.getElementById(modalId + 'Inner');
            modal.classList.add('opacity-0');
            inner.classList.add('scale-95');
            document.body.style.overflow = '';
            setTimeout(() => { modal.classList.add('hidden'); }, 300);
        };

        const setDepositAmount = (amount) => { document.getElementById('depositAmount').value = amount; };
        const setMaxWithdraw = () => { document.getElementById('withdrawAmount').value = Math.floor(state.balance); };

        const confirmDeposit = () => {
            const amt = parseFloat(document.getElementById('depositAmount').value);
            if(isNaN(amt) || amt <= 0) return showToast("Enter a valid amount", "error");
            
            state.users[state.currentUser].totalDeposited += amt;
            state.balance += amt;
            
            updateUI();
            closeModal('depositModal');
            showToast(`Successfully deposited ${formatMoney(amt)}`, "success");
        };

        const confirmWithdraw = () => {
            const amt = parseFloat(document.getElementById('withdrawAmount').value);
            if(isNaN(amt) || amt <= 0) return showToast("Enter a valid amount", "error");
            if(amt > state.balance) return showToast("Insufficient balance", "error");
            state.balance -= amt;
            updateUI();
            closeModal('withdrawModal');
            showToast(`Successfully withdrew ${formatMoney(amt)}`, "success");
        };

        const submitSupportTicket = () => {
            const type = document.getElementById('supportType').value;
            const desc = document.getElementById('supportDesc').value;

            if(!type) return showToast("Please select an issue type", "error");
            if(desc.trim().length < 10) return showToast("Please provide a more detailed description", "error");

            document.getElementById('supportType').value = "";
            document.getElementById('supportRef').value = "";
            document.getElementById('supportDesc').value = "";

            showToast("Ticket submitted successfully! Support will contact you shortly.", "success");
            
            setTimeout(() => { navigate('dashboard'); }, 1000);
        };

        // --- TOAST SYSTEM ---
        const showToast = (message, type = "info") => {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            
            let bgClass = "bg-gray-800 border border-gray-700";
            let icon = '<i class="fas fa-info-circle text-blue-400"></i>';
            if(type === "success") { bgClass = "bg-green-900 border border-green-700"; icon = '<i class="fas fa-check-circle text-green-400"></i>'; }
            if(type === "error") { bgClass = "bg-red-900 border border-red-700"; icon = '<i class="fas fa-exclamation-circle text-red-400"></i>'; }
            if(type === "win") { bgClass = "bg-gradient-to-r from-yellow-600 to-yellow-500 text-black border border-yellow-400"; icon = '<i class="fas fa-trophy text-black"></i>'; }

            toast.className = `toast ${bgClass}`;
            toast.innerHTML = `${icon} <span>${message}</span>`;
            
            container.appendChild(toast);
            
            setTimeout(() => {
                toast.style.animation = "slideOut 0.3s ease-in forwards";
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        };

        // --- GAME HELPERS ---
        const validateBet = (betInputId) => {
            const bet = parseFloat(document.getElementById(betInputId).value);
            if(isNaN(bet) || bet <= 0) { showToast("Invalid bet amount", "error"); return false; }
            if(bet > state.balance && state.freeSpins === 0) { showToast("Insufficient balance", "error"); return false; }
            return bet;
        };

        const processBet = (amount) => {
            state.balance -= amount;
            state.stats.wagered += amount;
            state.stats.gamesPlayed++;
            updateUI();
        };

        const processWin = (amount) => {
            state.balance += amount;
            state.stats.won += amount;
            updateUI();
        };

        const registerGameResult = (actualBet, winAmt) => {
            if (winAmt < actualBet) {
                const loss = actualBet - winAmt;
                state.users[state.currentUser].claimableCashback += (loss * 0.10);
                updateUI();
            }
        };

        // --- DICE GAME ---
        const selectDiceTarget = (target) => {
            if(state.gameIsRunning) return;
            state.diceTarget = target;
            document.getElementById('btnDiceLow').classList.remove('border-brand', 'text-white');
            document.getElementById('btnDiceLow').classList.add('border-transparent', 'text-gray-400');
            document.getElementById('btnDiceHigh').classList.remove('border-brand', 'text-white');
            document.getElementById('btnDiceHigh').classList.add('border-transparent', 'text-gray-400');
            
            const activeBtn = target === 'low' ? 'btnDiceLow' : 'btnDiceHigh';
            document.getElementById(activeBtn).classList.remove('border-transparent', 'text-gray-400');
            document.getElementById(activeBtn).classList.add('border-brand', 'text-white');
        };

        const getDiceIcon = (num) => {
            const icons = ['one', 'two', 'three', 'four', 'five', 'six'];
            return `fa-dice-${icons[num-1]}`;
        };

        const playDice = () => {
            if(state.gameIsRunning) return;
            const bet = validateBet('diceBet');
            if(!bet) return;

            state.gameIsRunning = true;
            processBet(bet);
            
            const btn = document.getElementById('btnRollDice');
            btn.disabled = true;
            btn.classList.add('opacity-50');
            document.getElementById('diceResultText').innerText = '';

            const die1El = document.getElementById('die1');
            const die2El = document.getElementById('die2');
            
            die1El.className = "fas fa-dice-one text-5xl sm:text-7xl text-white drop-shadow-[0_0_15px_rgba(255,255,255,0.2)] dice-rolling";
            die2El.className = "fas fa-dice-one text-5xl sm:text-7xl text-white drop-shadow-[0_0_15px_rgba(255,255,255,0.2)] dice-rolling";

            let rolls = 0;
            const rollAnim = setInterval(() => {
                die1El.className = `fas ${getDiceIcon(Math.floor(Math.random()*6)+1)} text-5xl sm:text-7xl text-white dice-rolling`;
                die2El.className = `fas ${getDiceIcon(Math.floor(Math.random()*6)+1)} text-5xl sm:text-7xl text-white dice-rolling`;
                rolls++;
                if(rolls > 15) {
                    clearInterval(rollAnim);
                    const d1 = Math.floor(Math.random() * 6) + 1;
                    const d2 = Math.floor(Math.random() * 6) + 1;
                    const total = d1 + d2;
                    
                    die1El.className = `fas ${getDiceIcon(d1)} text-5xl sm:text-7xl text-white drop-shadow-[0_0_20px_rgba(99,102,241,0.8)]`;
                    die2El.className = `fas ${getDiceIcon(d2)} text-5xl sm:text-7xl text-white drop-shadow-[0_0_20px_rgba(99,102,241,0.8)]`;

                    let isWin = false;
                    let winAmt = 0;
                    if(state.diceTarget === 'low' && total <= 7) isWin = true;
                    if(state.diceTarget === 'high' && total >= 8) isWin = true;

                    const resText = document.getElementById('diceResultText');
                    if(isWin) {
                        winAmt = bet * 2.00;
                        processWin(winAmt);
                        resText.innerText = `Rolled ${total}! You won ${formatMoney(winAmt)}`;
                        resText.className = "text-center text-xl sm:text-2xl font-bold mb-6 sm:mb-8 h-8 text-green-400 flex items-center justify-center";
                        showToast(`Dice: Won ${formatMoney(winAmt)}!`, "win");
                    } else {
                        resText.innerText = `Rolled ${total}. You lost.`;
                        resText.className = "text-center text-xl sm:text-2xl font-bold mb-6 sm:mb-8 h-8 text-red-400 flex items-center justify-center";
                    }

                    registerGameResult(bet, winAmt);

                    btn.disabled = false;
                    btn.classList.remove('opacity-50');
                    state.gameIsRunning = false;
                }
            }, 50);
        };

        // --- COIN FLIP GAME ---
        const selectCoinTarget = (target) => {
            if(state.gameIsRunning) return;
            state.coinTarget = target;
            document.getElementById('btnCoinHeads').classList.remove('border-yellow-400', 'text-white');
            document.getElementById('btnCoinHeads').classList.add('border-transparent', 'text-gray-400');
            document.getElementById('btnCoinTails').classList.remove('border-yellow-400', 'text-white');
            document.getElementById('btnCoinTails').classList.add('border-transparent', 'text-gray-400');
            
            const activeBtn = target === 'heads' ? 'btnCoinHeads' : 'btnCoinTails';
            document.getElementById(activeBtn).classList.remove('border-transparent', 'text-gray-400');
            document.getElementById(activeBtn).classList.add('border-yellow-400', 'text-white');
        };

        let coinCurrentRot = 0;
        const playCoin = () => {
            if(state.gameIsRunning) return;
            const bet = validateBet('coinBet');
            if(!bet) return;

            state.gameIsRunning = true;
            processBet(bet);
            
            const btn = document.getElementById('btnFlipCoin');
            btn.disabled = true;
            btn.classList.add('opacity-50');

            const result = Math.random() < 0.5 ? 'heads' : 'tails';
            const isWin = result === state.coinTarget;

            const coin = document.getElementById('coinObj');
            const spins = 5; 
            
            let addedRot = spins * 360;
            if(result === 'tails') addedRot += 180;
            
            coin.style.transition = 'none';
            coin.style.transform = `rotateY(0deg)`;
            
            setTimeout(() => {
                coin.style.transition = 'transform 3s cubic-bezier(0.2, 0.8, 0.2, 1)';
                let finalRot = addedRot;
                if(result === 'tails') finalRot = spins * 360 + 180;
                else finalRot = spins * 360;
                
                coin.style.transform = `rotateY(${finalRot}deg)`;

                setTimeout(() => {
                    let winAmt = 0;
                    if(isWin) {
                        winAmt = bet * 1.95;
                        processWin(winAmt);
                        showToast(`Coin landed on ${result.toUpperCase()}! Won ${formatMoney(winAmt)}`, "win");
                    } else {
                        showToast(`Coin landed on ${result.toUpperCase()}. You lost.`, "error");
                    }
                    
                    registerGameResult(bet, winAmt);
                    
                    btn.disabled = false;
                    btn.classList.remove('opacity-50');
                    state.gameIsRunning = false;
                }, 3000);
            }, 50);
        };

        // --- ROULETTE GAME ---
        let rouletteRot = 0;
        const playRoulette = (target) => {
            if(state.gameIsRunning) return;
            const bet = validateBet('rouletteBet');
            if(!bet) return;

            state.gameIsRunning = true;
            processBet(bet);

            const resText = document.getElementById('rouletteResult');
            resText.innerText = '';
            
            const wheel = document.getElementById('rouletteWheel');
            
            const resultNum = Math.floor(Math.random() * 37);
            let resultColor = 'green';
            let targetAngle = 0; 
            
            if(resultNum >= 1 && resultNum <= 18) {
                resultColor = 'red';
                targetAngle = 20 + Math.random() * 165; 
            } else if (resultNum >= 19 && resultNum <= 36) {
                resultColor = 'black';
                targetAngle = 195 + Math.random() * 160;
            } else {
                targetAngle = 2 + Math.random() * 14;
            }

            const spins = 5;
            const targetRotationMod = 360 - targetAngle;
            const currentMod = rouletteRot % 360;
            
            let rotationNeeded = targetRotationMod - currentMod;
            if (rotationNeeded < 0) rotationNeeded += 360;

            const finalRot = (spins * 360) + rotationNeeded;

            rouletteRot += finalRot;
            wheel.style.transform = `rotate(${rouletteRot}deg)`;

            setTimeout(() => {
                let isWin = false;
                let multiplier = 0;
                let winAmt = 0;
                
                if(target === resultColor) {
                    isWin = true;
                    multiplier = target === 'green' ? 14 : 2;
                }

                if(isWin) {
                    winAmt = bet * multiplier;
                    processWin(winAmt);
                    resText.innerText = `Landed on ${resultColor.toUpperCase()}`;
                    resText.className = `mt-6 sm:mt-8 text-xl sm:text-2xl font-bold h-8 tracking-widest uppercase flex items-center justify-center ${resultColor === 'red' ? 'text-red-500' : (resultColor==='green' ? 'text-emerald-500' : 'text-gray-400')}`;
                    showToast(`Roulette: Won ${formatMoney(winAmt)}!`, "win");
                } else {
                    resText.innerText = `Landed on ${resultColor.toUpperCase()}`;
                    resText.className = `mt-6 sm:mt-8 text-xl sm:text-2xl font-bold h-8 tracking-widest uppercase flex items-center justify-center ${resultColor === 'red' ? 'text-red-500' : (resultColor==='green' ? 'text-emerald-500' : 'text-gray-400')}`;
                }
                
                registerGameResult(bet, winAmt);
                state.gameIsRunning = false;
            }, 4000);
        };

        // --- SLOT MACHINE GAME ---
        const SYMBOLS = ['🍒', '🍋', '🍉', '🍇', '💎', '7️⃣', '🌟'];
        const WEIGHTS = [30,   25,   20,   12,   8,    3,    2]; 

        const getRandomSymbol = () => {
            let rnd = Math.random() * 100;
            let sum = 0;
            for(let i=0; i<SYMBOLS.length; i++) {
                sum += WEIGHTS[i];
                if(rnd <= sum) return SYMBOLS[i];
            }
            return SYMBOLS[0];
        };

        const checkLines = (grid) => {
            const lines = [
                [0,1,2], [3,4,5], [6,7,8], 
                [0,3,6], [1,4,7], [2,5,8], 
                [0,4,8], [2,4,6]           
            ];
            
            let winMultiplier = 0;
            let winningLines = [];

            lines.forEach(line => {
                const s1 = grid[line[0]];
                const s2 = grid[line[1]];
                const s3 = grid[line[2]];
                
                if(s1 === s2 && s2 === s3 && s1 !== '🌟') {
                    winningLines.push(line);
                    if(s1 === '7️⃣') winMultiplier += 50;
                    else if(s1 === '💎') winMultiplier += 25;
                    else if(s1 === '🍇') winMultiplier += 10;
                    else if(s1 === '🍉') winMultiplier += 5;
                    else if(s1 === '🍋') winMultiplier += 3;
                    else if(s1 === '🍒') winMultiplier += 2;
                }
            });

            const scatters = grid.filter(s => s === '🌟').length;

            return { multiplier: winMultiplier, lines: winningLines, scatters };
        };

        const playSlot = () => {
            if(state.gameIsRunning) return;
            
            let bet = parseFloat(document.getElementById('slotBet').value);
            let actualBetDeducted = 0;
            
            if(state.freeSpins > 0) {
                bet = parseFloat(document.getElementById('slotBet').value); 
                state.freeSpins--;
                updateUI(); 
            } else {
                bet = validateBet('slotBet');
                if(!bet) return;
                actualBetDeducted = bet;
                processBet(bet);
            }

            state.gameIsRunning = true;
            
            const btn = document.getElementById('btnSpinSlot');
            btn.disabled = true;
            btn.classList.add('opacity-50');
            
            const resDisplay = document.getElementById('slotWinDisplay');
            resDisplay.innerText = '';

            for(let i=0; i<9; i++) {
                const el = document.getElementById(`slot-${i}`);
                el.classList.remove('win-line', 'slot-stop');
                el.classList.add('slot-spinning');
            }

            const grid = [];
            for(let i=0; i<9; i++) grid.push(getRandomSymbol());

            const stopColumn = (colIndex, delay) => {
                setTimeout(() => {
                    for(let r=0; r<3; r++) {
                        const idx = r * 3 + colIndex;
                        const el = document.getElementById(`slot-${idx}`);
                        el.classList.remove('slot-spinning');
                        el.innerText = grid[idx];
                        el.classList.add('slot-stop');
                    }
                }, delay);
            };

            stopColumn(0, 600);
            stopColumn(1, 1200);
            stopColumn(2, 1800);

            setTimeout(() => {
                const result = checkLines(grid);

                let totalWin = bet * result.multiplier;
                
                result.lines.forEach(line => {
                    line.forEach(idx => document.getElementById(`slot-${idx}`).classList.add('win-line'));
                });

                if(result.multiplier > 0) {
                    processWin(totalWin);
                    resDisplay.innerText = `WIN: ${formatMoney(totalWin)}!`;
                    showToast(`Slots: Big Win ${formatMoney(totalWin)}!`, "win");
                } else if (result.scatters >= 3) {
                    resDisplay.innerText = ``;
                } else {
                    resDisplay.innerText = `Try Again`;
                    resDisplay.className = "text-center mt-5 sm:mt-6 text-xl sm:text-2xl font-bold h-8 text-gray-500 flex items-center justify-center";
                }
                
                registerGameResult(actualBetDeducted, totalWin);

                if(result.scatters >= 3) {
                    state.freeSpins += 10;
                    setTimeout(() => {
                        showToast("🎰 10 FREE SPINS TRIGGERED! 🎰", "win");
                        updateUI();
                    }, 500);
                }

                btn.disabled = false;
                btn.classList.remove('opacity-50');
                state.gameIsRunning = false;

            }, 2000); 
        };

        // --- CRASH ROAD GAME ---
        let crState = {
            active: false,
            bet: 0,
            currentMultiplier: 1.00,
            crashPoint: 1.00,
            autoCashout: Infinity,
            animationFrame: null,
            startTime: 0,
            cashedOut: false
        };

        const startChicken = () => {
            if(crState.active || state.gameIsRunning) return;
            const bet = validateBet('chickenBet');
            if(!bet) return;

            let autoCash = parseFloat(document.getElementById('crAutoCashout').value);
            if(isNaN(autoCash) || autoCash <= 1.00) autoCash = Infinity;

            state.gameIsRunning = true; 
            processBet(bet);
            
            crState.active = true;
            crState.bet = bet;
            crState.autoCashout = autoCash;
            crState.currentMultiplier = 1.00;
            crState.cashedOut = false;

            crState.crashPoint = Math.max(1.00, 0.99 / Math.random());
            if(crState.crashPoint <= 1.01) crState.crashPoint = 1.00;

            document.getElementById('btnChickenStart').classList.add('hidden');
            const cashBtn = document.getElementById('btnChickenCashout');
            cashBtn.classList.remove('hidden');
            cashBtn.disabled = false;
            cashBtn.classList.remove('opacity-50');
            cashBtn.innerText = `Cashout ${formatMoney(bet)}`;

            const multDisplay = document.getElementById('crMultiplierDisplay');
            multDisplay.innerText = "1.00x";
            multDisplay.className = "absolute top-10 left-1/2 transform -translate-x-1/2 text-6xl sm:text-7xl font-extrabold font-mono text-white z-20 drop-shadow-[0_5px_15px_rgba(0,0,0,0.8)] transition-colors duration-300";

            const road = document.getElementById('crRoad');
            road.classList.add('cr-animating');
            
            const chicken = document.getElementById('crChicken');
            chicken.innerText = "🚎";
            chicken.style.transform = "translateX(0) translateY(0)";
            chicken.style.transition = "none";

            crState.startTime = performance.now();
            crState.animationFrame = requestAnimationFrame(chickenLoop);
        };

        const chickenLoop = (time) => {
            if(!crState.active) return;

            const elapsed = time - crState.startTime;
            crState.currentMultiplier = Math.pow(Math.E, 0.00015 * elapsed);
            if (crState.currentMultiplier < 1.00) crState.currentMultiplier = 1.00;

            if (crState.currentMultiplier >= crState.crashPoint) {
                crashChicken();
                return;
            }

            const displayMult = crState.currentMultiplier.toFixed(2);
            document.getElementById('crMultiplierDisplay').innerText = `${displayMult}x`;
            document.getElementById('btnChickenCashout').innerText = `Cashout ${formatMoney(crState.bet * crState.currentMultiplier)}`;

            if (crState.currentMultiplier >= crState.autoCashout && !crState.cashedOut) {
                crState.currentMultiplier = crState.autoCashout;
                cashoutChicken(true);
                return;
            }

            crState.animationFrame = requestAnimationFrame(chickenLoop);
        };

        const cashoutChicken = (isAuto = false) => {
            if(!crState.active || crState.cashedOut) return;
            crState.cashedOut = true;
            crState.active = false;

            const winAmt = crState.bet * crState.currentMultiplier;
            processWin(winAmt);
            registerGameResult(crState.bet, winAmt);

            document.getElementById('crMultiplierDisplay').innerText = `${crState.currentMultiplier.toFixed(2)}x`;
            document.getElementById('crMultiplierDisplay').classList.replace('text-white', 'text-green-500');
            
            document.getElementById('crRoad').classList.remove('cr-animating');
            const chicken = document.getElementById('crChicken');
            chicken.innerText = "💨🚎"; 
            chicken.style.transition = "transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275)";
            chicken.style.transform = "translateX(150px) translateY(-10px)";

            showToast(`${isAuto ? 'Auto ' : ''}Cashed out! Won ${formatMoney(winAmt)}`, "win");
            
            resetChickenUI();
        };

        const crashChicken = () => {
            crState.active = false;
            
            document.getElementById('crMultiplierDisplay').innerText = `${crState.crashPoint.toFixed(2)}x`;
            document.getElementById('crMultiplierDisplay').classList.replace('text-white', 'text-red-500');
            
            document.getElementById('crRoad').classList.remove('cr-animating');
            
            const chicken = document.getElementById('crChicken');
            chicken.innerText = "💥🚎"; 
            chicken.style.transition = "none";
            chicken.style.transform = "translateX(0) translateY(10px)";
            
            registerGameResult(crState.bet, 0); 
            showToast(`Crashed at ${crState.crashPoint.toFixed(2)}x!`, "error");

            resetChickenUI();
        };

        const resetChickenUI = () => {
            state.gameIsRunning = false;
            const startBtn = document.getElementById('btnChickenStart');
            const cashBtn = document.getElementById('btnChickenCashout');
            
            setTimeout(() => {
                startBtn.classList.remove('hidden');
                cashBtn.classList.add('hidden');
            }, 1500); 
        };

        // --- LIMBO GAME ---
        const updateLimboChance = () => {
            const target = parseFloat(document.getElementById('limboTarget').value);
            const chanceDisplay = document.getElementById('limboChance');
            if(isNaN(target) || target <= 1.00) {
                chanceDisplay.innerText = "0.00%";
                return;
            }
            let chance = 99 / target;
            if(chance > 99) chance = 99;
            chanceDisplay.innerText = `${chance.toFixed(2)}%`;
        };

        const playLimbo = () => {
            if(state.gameIsRunning) return;
            const bet = validateBet('limboBet');
            if(!bet) return;
            
            const target = parseFloat(document.getElementById('limboTarget').value);
            if(isNaN(target) || target <= 1.00) return showToast("Invalid Target Multiplier", "error");

            state.gameIsRunning = true;
            processBet(bet);

            const btn = document.getElementById('btnPlayLimbo');
            btn.disabled = true;
            btn.classList.add('opacity-50');
            
            const resDisplay = document.getElementById('limboResult');
            resDisplay.className = "text-6xl sm:text-7xl font-extrabold font-mono text-white transition-colors duration-300";

            const crashPoint = Math.max(1.00, 0.99 / Math.random());
            
            let currentDisplay = 1.00;
            const duration = 800; 
            const startTime = performance.now();

            const animateLimbo = (time) => {
                const elapsed = time - startTime;
                const progress = Math.min(elapsed / duration, 1);
                
                const easeOutExpo = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
                
                currentDisplay = 1.00 + (crashPoint - 1.00) * easeOutExpo;
                resDisplay.innerText = `${currentDisplay.toFixed(2)}x`;

                if(progress < 1) {
                    requestAnimationFrame(animateLimbo);
                } else {
                    resDisplay.innerText = `${crashPoint.toFixed(2)}x`;
                    resDisplay.classList.add('limbo-pop');
                    
                    let winAmt = 0;
                    if(crashPoint >= target) {
                        winAmt = bet * target;
                        processWin(winAmt);
                        resDisplay.classList.replace('text-white', 'text-green-500');
                        showToast(`Limbo: Won ${formatMoney(winAmt)}!`, "win");
                    } else {
                        resDisplay.classList.replace('text-white', 'text-red-500');
                    }

                    registerGameResult(bet, winAmt);
                    
                    btn.disabled = false;
                    btn.classList.remove('opacity-50');
                    state.gameIsRunning = false;
                    
                    setTimeout(() => resDisplay.classList.remove('limbo-pop'), 300);
                }
            };
            
            requestAnimationFrame(animateLimbo);
        };

        // --- MINES GAME ---
        let minesState = {
            active: false,
            bet: 0,
            minesCount: 3,
            grid: [], // 0 = gem, 1 = mine
            revealedCount: 0,
            currentMult: 1.00
        };

        const calcMinesMult = (mines, revealed) => {
            if(revealed === 0) return 1.00;
            let prob = 1;
            for (let i = 0; i < revealed; i++) {
                prob *= (25 - mines - i) / (25 - i);
            }
            return 0.99 / prob;
        };

        const initMinesGrid = () => {
            const gridEl = document.getElementById('minesGrid');
            gridEl.innerHTML = '';
            for(let i=0; i<25; i++) {
                const cell = document.createElement('div');
                cell.className = 'mine-cell disabled';
                cell.id = `mine-cell-${i}`;
                cell.onclick = () => clickMine(i);
                gridEl.appendChild(cell);
            }
        };

        const startMines = () => {
            if(minesState.active || state.gameIsRunning) return;
            const bet = validateBet('minesBet');
            if(!bet) return;
            
            const minesCount = parseInt(document.getElementById('minesCount').value);
            if(isNaN(minesCount) || minesCount < 1 || minesCount > 24) return showToast("Mines must be between 1 and 24", "error");

            state.gameIsRunning = true;
            processBet(bet);

            minesState.active = true;
            minesState.bet = bet;
            minesState.minesCount = minesCount;
            minesState.revealedCount = 0;
            minesState.currentMult = 1.00;

            // Generate Board
            minesState.grid = new Array(25).fill(0);
            let placed = 0;
            while(placed < minesCount) {
                let r = Math.floor(Math.random() * 25);
                if(minesState.grid[r] === 0) {
                    minesState.grid[r] = 1;
                    placed++;
                }
            }

            // UI Resets
            for(let i=0; i<25; i++) {
                const cell = document.getElementById(`mine-cell-${i}`);
                cell.className = 'mine-cell';
                cell.innerHTML = '';
            }

            document.getElementById('minesCount').disabled = true;
            document.getElementById('minesBet').disabled = true;
            
            document.getElementById('btnMinesStart').classList.add('hidden');
            const cashBtn = document.getElementById('btnMinesCashout');
            cashBtn.classList.remove('hidden');
            cashBtn.disabled = true;
            cashBtn.classList.add('opacity-50');
            cashBtn.innerText = `Cashout ${formatMoney(bet)}`;

            document.getElementById('minesMultiBox').classList.remove('hidden');
            document.getElementById('minesNextMult').innerText = `${calcMinesMult(minesCount, 1).toFixed(2)}x`;
        };

        const clickMine = (index) => {
            if(!minesState.active) return;
            const cell = document.getElementById(`mine-cell-${index}`);
            if(cell.classList.contains('revealed')) return;

            cell.classList.add('revealed');

            if(minesState.grid[index] === 1) {
                // Hit a mine
                cell.classList.add('mine');
                cell.innerHTML = '💣';
                endMinesGame(false);
            } else {
                // Hit a gem
                cell.classList.add('gem');
                cell.innerHTML = '💎';
                minesState.revealedCount++;
                minesState.currentMult = calcMinesMult(minesState.minesCount, minesState.revealedCount);
                
                const cashBtn = document.getElementById('btnMinesCashout');
                cashBtn.disabled = false;
                cashBtn.classList.remove('opacity-50');
                cashBtn.innerText = `Cashout ${formatMoney(minesState.bet * minesState.currentMult)}`;
                
                // Max win condition (revealed all gems)
                if(minesState.revealedCount === (25 - minesState.minesCount)) {
                    cashoutMines();
                } else {
                    document.getElementById('minesNextMult').innerText = `${calcMinesMult(minesState.minesCount, minesState.revealedCount + 1).toFixed(2)}x`;
                }
            }
        };

        const cashoutMines = () => {
            if(!minesState.active || minesState.revealedCount === 0) return;
            endMinesGame(true);
        };

        const endMinesGame = (isWin) => {
            minesState.active = false;
            
            // Reveal remaining
            for(let i=0; i<25; i++) {
                const cell = document.getElementById(`mine-cell-${i}`);
                if(!cell.classList.contains('revealed')) {
                    cell.classList.add('revealed', 'transparent');
                    cell.innerHTML = minesState.grid[i] === 1 ? '💣' : '💎';
                }
            }

            let winAmt = 0;
            if(isWin) {
                winAmt = minesState.bet * minesState.currentMult;
                processWin(winAmt);
                showToast(`Mines: Cashed out ${formatMoney(winAmt)}!`, "win");
            } else {
                showToast(`Hit a mine! You lost.`, "error");
            }
            
            registerGameResult(minesState.bet, winAmt);

            document.getElementById('btnMinesStart').classList.remove('hidden');
            document.getElementById('btnMinesCashout').classList.add('hidden');
            document.getElementById('minesMultiBox').classList.add('hidden');
            document.getElementById('minesCount').disabled = false;
            document.getElementById('minesBet').disabled = false;
            
            state.gameIsRunning = false;
        };


        // --- PLINKO GAME ---
        const PLINKO_LEVELS = 8;
        const PLINKO_MULTIPLIERS = {
            low: [5.6, 2.1, 1.1, 1.0, 0.5, 1.0, 1.1, 2.1, 5.6],
            medium: [29, 4, 1.5, 0.3, 0.2, 0.3, 1.5, 4, 29],
            high: [120, 14, 2.0, 0.2, 0.2, 0.2, 2.0, 14, 120]
        };

        const initPlinko = () => {
            const pegsContainer = document.getElementById('plinkoPegs');
            pegsContainer.innerHTML = '';
            
            // Build Pegs (Triangle)
            for(let row = 0; row < PLINKO_LEVELS; row++) {
                let numPegs = row + 3; // Top row has 3 pegs
                for(let col = 0; col < numPegs; col++) {
                    const peg = document.createElement('div');
                    peg.className = 'plinko-peg';
                    // Calculate position
                    const rowHeightPerc = (row + 1) / (PLINKO_LEVELS + 1) * 100;
                    // Spread pegs horizontally
                    const pegSpacing = 100 / numPegs;
                    const offset = pegSpacing / 2;
                    const colWidthPerc = (col * pegSpacing) + offset;
                    
                    peg.style.top = `${rowHeightPerc}%`;
                    peg.style.left = `${colWidthPerc}%`;
                    pegsContainer.appendChild(peg);
                }
            }

            updatePlinkoMultipliers();
        };

        const updatePlinkoMultipliers = () => {
            if(state.gameIsRunning) return;
            const risk = document.getElementById('plinkoRisk').value;
            const mults = PLINKO_MULTIPLIERS[risk];
            const container = document.getElementById('plinkoMultipliers');
            container.innerHTML = '';

            mults.forEach((m, idx) => {
                const box = document.createElement('div');
                let colorClass = 'p-color-low';
                if(m >= 10) colorClass = 'p-color-high';
                else if(m >= 2) colorClass = 'p-color-med';
                else if (m < 1) { box.style.backgroundColor = '#334155'; box.style.color = '#94A3B8'; }
                
                box.className = `plinko-mult-box ${colorClass}`;
                box.id = `plinko-bin-${idx}`;
                box.innerText = `${m}x`;
                container.appendChild(box);
            });
        };

        const playPlinko = () => {
            if(state.gameIsRunning) return;
            const bet = validateBet('plinkoBet');
            if(!bet) return;
            
            const risk = document.getElementById('plinkoRisk').value;
            
            state.gameIsRunning = true;
            processBet(bet);
            
            const btn = document.getElementById('btnPlinkoDrop');
            btn.disabled = true;
            btn.classList.add('opacity-50');

            // Reset active bins
            document.querySelectorAll('.plinko-mult-box').forEach(el => el.classList.remove('active'));

            // Calculate path
            let currentBin = 0;
            const path = [];
            for(let i=0; i < PLINKO_LEVELS; i++) {
                const dir = Math.random() > 0.5 ? 1 : 0;
                currentBin += dir;
                path.push(dir);
            }

            const ball = document.getElementById('plinkoBall');
            ball.style.transition = 'none';
            ball.style.top = '0%';
            ball.style.left = '50%';
            ball.classList.add('active');

            let currentStep = 0;
            // Center is 50%. The drop widens as it goes down.
            let currentLeft = 50; 
            const horizontalSpread = 45; // Max % it can go left/right from center

            const dropStep = () => {
                currentStep++;
                
                const topPerc = (currentStep / PLINKO_LEVELS) * 90; // Move down
                
                // Calculate left
                // Path tells us number of rights.
                // At step `currentStep`, maximum rights is `currentStep`.
                // We want to map current rights vs currentStep to a percentage
                let rightsSoFar = path.slice(0, currentStep).reduce((a,b) => a+b, 0);
                // Map to -1 to 1 range
                let normalizedPos = (rightsSoFar / currentStep) * 2 - 1; 
                // However, the triangle widens linearly. 
                // Actual Left = 50% + (normalizedPos * horizontalSpread * (currentStep / PLINKO_LEVELS))
                
                let targetLeft = 50 + (normalizedPos * horizontalSpread * (currentStep / PLINKO_LEVELS));
                
                ball.style.transition = 'top 0.3s cubic-bezier(0.4, 0, 1, 1), left 0.3s cubic-bezier(0.4, 0, 1, 1)';
                ball.style.top = `${topPerc}%`;
                ball.style.left = `${targetLeft}%`;

                if(currentStep < PLINKO_LEVELS) {
                    setTimeout(dropStep, 300);
                } else {
                    // Reached bottom
                    setTimeout(() => {
                        ball.style.top = '100%';
                        // Final alignment to the specific bin box
                        const targetBinOffset = (currentBin / PLINKO_LEVELS) * 96 + 2; 
                        ball.style.left = `${targetBinOffset}%`;
                        
                        setTimeout(() => {
                            const mult = PLINKO_MULTIPLIERS[risk][currentBin];
                            const winAmt = bet * mult;
                            const binEl = document.getElementById(`plinko-bin-${currentBin}`);
                            binEl.classList.add('active');

                            if(winAmt >= bet) {
                                processWin(winAmt);
                                showToast(`Plinko: Won ${formatMoney(winAmt)}!`, "win");
                            } else {
                                processWin(winAmt); // Returns fraction of bet
                            }

                            registerGameResult(bet, winAmt);
                            
                            setTimeout(() => { ball.classList.remove('active'); }, 500);
                            
                            btn.disabled = false;
                            btn.classList.remove('opacity-50');
                            state.gameIsRunning = false;
                        }, 200);
                    }, 300);
                }
            };

            // Start drop animation
            setTimeout(dropStep, 100);
        };


        // --- INITIAL BOOT ---
        initMinesGrid();
        initPlinko();
        if (state.currentUser && state.users[state.currentUser]) {
            updateUI();
            navigate('dashboard');
        } else {
            updateUI();
            navigate('auth'); 
        }

    </script>
</body>
</html>
